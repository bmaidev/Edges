# Copy to .env.local for local dev, and set as Vercel project env vars in prod.
# This file is the authoritative list of every environment variable the code
# reads. Do NOT put real secrets here.

# --- Auth -------------------------------------------------------------------

# Required (for the /admin portal): the bootstrap super-admin passcode. It can
# create rooms before any room exists, and authenticates as "admin" in any room.
# Read by lib/rooms.ts (isSuperAdmin / superAdminConfigured). Per-room
# facilitator/co-host/projector passcodes are generated per room at creation —
# they are NOT env vars.
ADMIN_PASSCODE=change-me

# --- AI ---------------------------------------------------------------------

# Optional but recommended: the BASELINE Anthropic key that powers ALL AI
# features — cluster assist, the AI modules (devil's-advocate, friction map,
# synthesis, persona, empty-chair, issue-map, prompt-relay, builder, latent-
# needs), the setup design assistant, and the post-session report. Workspaces can
# BRING THEIR OWN key on top of this (so their AI bills + routes through their own
# Anthropic account); this baseline keeps AI available for keyless workspaces. If
# neither is set, AI degrades gracefully ("AI unavailable") and no submission text
# is ever sent to an LLM. Read by lib/ai.ts.
ANTHROPIC_API_KEY=

# Optional: a 16+ char master secret that ENCRYPTS each workspace's bring-your-own
# Anthropic key at rest (AES-256-GCM). REQUIRED to enable per-workspace BYO keys —
# without it, BYO is disabled (the baseline key above still works) and no secret
# is ever stored unprotected. Read by lib/secrets.ts. Generate one with e.g.
# `openssl rand -hex 32`.
EDGES_SECRET_KEY=

# --- Self-service signup ----------------------------------------------------

# Controls who can create a workspace at /start (multi-tenant onboarding). Three
# operator modes, read by lib/signup.ts:
#   SIGNUP_OPEN=true            -> anyone can create a workspace, no code
#   else SIGNUP_CODE=<secret>   -> gated by a shared community code
#   else (neither set)          -> closed; only the super-admin mints workspaces
SIGNUP_OPEN=
SIGNUP_CODE=

# --- Persistence (Vercel KV / Upstash Redis) --------------------------------

# Vercel KV (Redis) — provisioned automatically when you connect a KV/Upstash
# store to the Vercel project. Required in production for durable storage; if
# omitted (e.g. local dev) an in-memory store is used, which resets whenever the
# dev server restarts. Read by lib/store.ts and lib/rooms.ts.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Upstash equivalents — used as a fallback when the KV_REST_API_* pair is unset
# (some Upstash integrations expose these names instead). Set either pair, not
# both. Read by lib/store.ts and lib/rooms.ts.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- File uploads -----------------------------------------------------------

# Optional: Vercel Blob token, required only for admin LOGO uploads
# (app/api/admin/upload). Without it, logo upload is disabled and you paste a logo
# URL instead; everything else works normally. Provisioned by connecting a Blob
# store in Vercel. (Not available on non-Vercel hosts — use logo-by-URL there.)
BLOB_READ_WRITE_TOKEN=

# --- Session defaults (legacy single-room) ----------------------------------

# Optional legacy defaults for the original single-room id/topic, read by
# lib/session.ts. The multi-room/workspace platform passes a real room id per
# call, so these are only the fallback default-room identity and rarely needed.
SESSION_ID=edges
SESSION_TOPIC=Teaming and organisational change
