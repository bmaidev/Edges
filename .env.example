# Copy to .env.local for local dev, and set as Vercel project env vars in prod.
# This file is the authoritative list of every environment variable the code
# reads. Do NOT put real secrets here.

# --- Auth -------------------------------------------------------------------

# Required (for the /admin portal): the bootstrap super-admin passcode. It can
# create rooms before any room exists, and authenticates as "admin" in any room.
# Read by lib/rooms.ts (isSuperAdmin / superAdminConfigured). Per-room
# facilitator/co-host/projector passcodes are generated per room at creation —
# they are NOT env vars.
ADMIN_PASSCODE=change-me

# --- AI ---------------------------------------------------------------------

# Optional but recommended: powers ALL AI features — cluster assist, the AI
# modules (devil's-advocate, friction map, synthesis, persona, empty-chair,
# issue-map, prompt-relay, builder, latent-needs), the setup design assistant,
# and the post-session report. If unset, every AI feature degrades gracefully
# ("AI unavailable") and no submission text is ever sent to an LLM.
ANTHROPIC_API_KEY=

# --- Persistence (Vercel KV / Upstash Redis) --------------------------------

# Vercel KV (Redis) — provisioned automatically when you connect a KV/Upstash
# store to the Vercel project. Required in production for durable storage; if
# omitted (e.g. local dev) an in-memory store is used, which resets whenever the
# dev server restarts. Read by lib/store.ts and lib/rooms.ts.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Upstash equivalents — used as a fallback when the KV_REST_API_* pair is unset
# (some Upstash integrations expose these names instead). Set either pair, not
# both. Read by lib/store.ts and lib/rooms.ts.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- File uploads -----------------------------------------------------------

# Optional: Vercel Blob token, required only for admin image/file uploads
# (app/api/admin/upload). Without it the upload endpoint is disabled; the rest
# of the app works normally. Provisioned by connecting a Blob store in Vercel.
BLOB_READ_WRITE_TOKEN=

# --- Session defaults -------------------------------------------------------

# Optional: default session identity, read by lib/session.ts. Both have built-in
# fallbacks, so they are only needed to override the defaults shown below.
# SESSION_ID falls back to "edges".
SESSION_ID=edges
# SESSION_TOPIC falls back to "Teaming and organisational change".
SESSION_TOPIC=Teaming and organisational change
